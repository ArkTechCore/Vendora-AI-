DEBUG=False
DJANGO_SECRET_KEY=change-me
DJANGO_ALLOWED_HOSTS=vendoraops.example.com,localhost,127.0.0.1
DJANGO_CSRF_TRUSTED_ORIGINS=https://vendoraops.example.com

DJANGO_SESSION_COOKIE_SECURE=True
DJANGO_CSRF_COOKIE_SECURE=True
DJANGO_SECURE_SSL_REDIRECT=True
DJANGO_SECURE_HSTS_SECONDS=31536000
DJANGO_SECURE_HSTS_INCLUDE_SUBDOMAINS=True
DJANGO_SECURE_HSTS_PRELOAD=False
DJANGO_SESSION_COOKIE_AGE=28800

AXES_FAILURE_LIMIT=5
AXES_COOLOFF_TIME=1

# Built-in open-source SMTP path.
DJANGO_EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_HOST_USER=postmaster@example.com
EMAIL_HOST_PASSWORD=change-me
EMAIL_USE_TLS=True
DJANGO_DEFAULT_FROM_EMAIL=VendoraOps <no-reply@example.com>
PLATFORM_NOTIFICATION_EMAILS=admin@example.com

# Optional django-anymail path after installing requirements.
# DJANGO_EMAIL_BACKEND=anymail.backends.mailgun.EmailBackend
# ANYMAIL_MAILGUN_API_KEY=key-example
# ANYMAIL_MAILGUN_SENDER_DOMAIN=mg.example.com
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
MONGODB_URI=
MONGODB_DB=vendora_ai
NODE_ENV=production
PORT=8000
